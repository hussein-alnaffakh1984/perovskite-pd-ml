  "novel_contributions": [
    {
      "id": 1,
      "title": "First ML study on vacancy-ordered A2BX6 as photodetectors",
      "description": "We present the first systematic ML analysis of vacancy-ordered A2BX6 perovskites specifically for photodetector applications, achieving R²=0.936 for this structural family.",
      "evidence": "R²=0.936, n=69 vacancy-ordered materials",
      "novelty": "high"
    },
    {
      "id": 2,
      "title": "Multi-family framework covering 4 structural types",
      "description": "Unlike previous studies focusing on single ABX3, we cover single, double, vacancy-ordered, and Sb/Bi ternary families in one unified model.",
      "evidence": "370 materials, 4 families, R²=0.919",
      "novelty": "medium-high"
    },
    {
      "id": 3,
      "title": "Physics-informed Δxc correction",
      "description": "Calibrated derivative discontinuity corrections using 6 experimental references, improving agreement with experiment from R²=0.888 to R²=0.919.",
      "evidence": "MAE improvement: 0.618→0.236 eV after bias correction",
      "novelty": "medium"
    },
    {
      "id": 4,
      "title": "Inverse Design for photodetectors",
      "description": "Application-specific candidate discovery: NIR, Visible, UV-Vis photodetectors with stability and lead-free constraints.",
      "evidence": "253 candidates identified, 10/10 lead-free in top 10",
      "novelty": "medium-high"
    },
    {
      "id": 5,
      "title": "Spearman-validated screening utility",
      "description": "Demonstrated screening utility with Spearman ranking correlation of 0.829, confirming the model correctly orders materials by bandgap.",
      "evidence": "Spearman r=0.829, p=0.042",
      "novelty": "medium"
    }
